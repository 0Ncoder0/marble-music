{
  "name": "marble-music",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "matter-js": "^0.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jsdom": "^28.0.1",
    "@types/matter-js": "^0.19.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
